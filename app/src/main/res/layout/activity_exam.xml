<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="48dp">

    <!-- Top Bar: question index + timer -->
    <TextView
        android:id="@+id/qIndexTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="שאלה 1/10"
        android:textAppearance="@style/TextAppearance.Exam.Top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <TextView
        android:id="@+id/timerChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20s"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_timer_pill"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Progress -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginTop="10dp"
        android:indeterminate="false"
        app:trackCornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/qIndexTv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Question Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/questionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/questionTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="כאן תופיע השאלה..."
            android:textAppearance="@style/TextAppearance.Exam.Question"
            android:lineSpacingExtra="3dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Answers container (2 rows x 2 buttons) - stable, Kahoot-like -->
    <LinearLayout
        android:id="@+id/answersContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:orientation="vertical"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/questionCard"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnA"
                style="@style/Widget.Exam.AnswerButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_answer_red"
                android:text="A) תשובה 1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnB"
                style="@style/Widget.Exam.AnswerButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_answer_blue"
                android:text="B) תשובה 2" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnC"
                style="@style/Widget.Exam.AnswerButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_answer_yellow"
                android:text="C) תשובה 3" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnD"
                style="@style/Widget.Exam.AnswerButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_answer_green"
                android:text="D) תשובה 4" />
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/scoreTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ניקוד: 0"
            android:textAppearance="@style/TextAppearance.Exam.Top" />

        <Button
            android:id="@+id/hintBtn"
            style="@style/Widget.Exam.SecondaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="רמז" />

        <Button
            android:id="@+id/nextBtn"
            style="@style/Widget.Exam.PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הבא" />
    </LinearLayout>

    <!-- RESULT OVERLAY (Correct/Wrong screen) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/resultOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/resultCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/resultIcon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center_horizontal"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_check_circle_64" />

                <TextView
                    android:id="@+id/resultTitleTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="תשובה נכונה!"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:paddingTop="10dp" />

                <TextView
                    android:id="@+id/resultQuestionTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="השאלה כאן..."
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingTop="14dp" />

                <TextView
                    android:id="@+id/resultAnswerTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="התשובה הנכונה: ..."
                    android:textSize="16sp"
                    android:paddingTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>