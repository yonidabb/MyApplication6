<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication6"
        tools:targetApi="31">

        <service
            android:name=".jv.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name=".jv.JMainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".jv.ExamActivity"
            android:theme="@style/Theme.MyApplication.Exam"
            android:exported="true" >
        </activity>
        <activity
            android:name=".jv.AfterLoginActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".jv.DebugActivity"
            android:exported="true">
        </activity>

        <activity
            android:name=".jv.FirstQuestionActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="true"
            android:screenOrientation="landscape">
            <!-- Deep Link filter -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="myapp" android:host="firstquestion" />
            </intent-filter>
        </activity>
        <activity
            android:name=".item_score"
            android:exported="false" />
        <activity
            android:name=".jv.Activity_scores"
            android:exported="true" />
        <activity
            android:name=".jv.ScoresActivity"
            android:exported="true">
            <!-- Deep Link filter for Scores -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="myapp" android:host="scores" />
            </intent-filter>
        </activity>
        <activity
            android:name=".jv.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".jv.RegistrationActivity"
            android:exported="false" />
        <activity
            android:name=".jv.NextActivity"
            android:exported="false" /> <!-- 🔹 SERVICE של הטיימר -->
        <service
            android:name=".jv.CountdownService"
            android:exported="false" />

        <activity
            android:name=".jv.IranPuzzleActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".jv.IranQuestion1Activity" />
        <activity android:name=".jv.IranQuestion2Activity" />
        <activity android:name=".jv.IranQuestion3Activity" />
        <activity android:name=".jv.IranQuestion4Activity" />
        <activity android:name=".jv.IranQuestion5Activity" />
    </application>

</manifest>